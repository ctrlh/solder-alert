# Copy to secrets.yaml and fill in before building.
#
# WiFi credentials are NOT baked into the image — the device
# provisions via the captive portal on first boot.

# Fallback AP password used by captive_portal.
ap_password: "solder-alert-setup"

# API + OTA credentials.
api_encryption_key: "generate-with: esphome secrets generate-encryption-key"
ota_password: "generate-me"
